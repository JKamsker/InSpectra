{
  "info": {
    "title": "csharp-ls",
    "version": "0.22.0",
    "description": "C# LSP language server"
  },
  "options": [
    {
      "name": "--version",
      "description": "Show version information",
      "aliases": [
        "-v"
      ]
    },
    {
      "name": "--loglevel",
      "description": "set log level, \u003Ctrace|debug|info|warning|error\u003E;\ndefault is \u0060info\u0060",
      "aliases": [
        "-l"
      ],
      "arguments": [
        {
          "name": "LEVEL",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--solution",
      "description": "specify .sln file to load (relative to CWD)",
      "aliases": [
        "-s"
      ],
      "arguments": [
        {
          "name": "SOLUTION",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--debug",
      "description": "enable debug mode"
    },
    {
      "name": "--diagnose",
      "description": "run diagnostics"
    },
    {
      "name": "--features",
      "description": "enable optional features, comma-separated:\n[metadata-uris, razor-support]",
      "aliases": [
        "-f"
      ],
      "arguments": [
        {
          "name": "FEATURES",
          "required": true,
          "arity": {
            "minimum": 1,
            "maximum": 1
          }
        }
      ]
    },
    {
      "name": "--help",
      "description": "Show help and usage information"
    }
  ]
}